# SBOMix — local development environment
# Copy to .env and fill in values before running docker compose or npm run serve

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=sbomix
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
POSTGRES_PASSWORD=
POSTGRES_DB=sbomix

# Full connection string (used by the API server directly)
DATABASE_URL=postgresql://sbomix:<your-POSTGRES_PASSWORD>@localhost:5432/sbomix

# ── API server ────────────────────────────────────────────────────────────────

# Admin key — used to provision new organisations via POST /api/v1/orgs.
# Do NOT expose this endpoint on the public internet.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_KEY=

# HMAC secret — used to hash API keys before storing them in the database.
# Required. The plaintext key is never stored; only HMAC-SHA256(key, HMAC_SECRET) is.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HMAC_SECRET=

# API server port (optional, default: 3080)
# PORT=3080

# CORS allowed origin for the browser dashboard (optional).
# Set to the dashboard URL, e.g. https://app.sbomix.com
# Leave unset to disable CORS headers (server-to-server use only).
# CORS_ORIGIN=

# ── AI features (optional) ───────────────────────────────────────────────────

# AI explain — enables `sbomix --explain` (CLI) and POST /api/v1/apps/:name/explain (API).
# Default provider: Anthropic Claude Haiku (EU/US data residency).
# Get an API key at https://console.anthropic.com
# EXPLAIN_API_KEY=

# Override the AI provider (optional):
#   Anthropic Claude (default):
#     EXPLAIN_BASE_URL=https://api.anthropic.com/v1
#     EXPLAIN_MODEL=claude-haiku-4-5-20251001
#
#   Self-hosted via Ollama (no data leaves your machine):
#     EXPLAIN_BASE_URL=http://localhost:11434/v1
#     EXPLAIN_MODEL=llama3.2
#     (no EXPLAIN_API_KEY required)
#
#   Any other OpenAI-compatible provider:
#     EXPLAIN_BASE_URL=https://api.openai.com/v1
#     EXPLAIN_API_KEY=sk-...
#     EXPLAIN_MODEL=gpt-4o-mini
#
# EXPLAIN_BASE_URL=
# EXPLAIN_MODEL=

# Katzilla API key — enables CISA KEV enrichment.
# Flags vulnerabilities that are actively exploited in the wild (CISA KEV catalog).
# Refreshed daily. Get a key at https://katzilla.dev
# KATZILLA_API_KEY=

# ── CLI (optional) ────────────────────────────────────────────────────────────

# GitHub personal access token for scanning private repositories.
# Needs repo:read scope. Alternatively pass --token on the CLI.
# GITHUB_TOKEN=
